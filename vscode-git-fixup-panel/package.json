{
  "name": "vscode-git-fixup-panel",
  "displayName": "Git Fixup Panel",
  "description": "Create fixup commits and run autosquash rebase from VS Code",
  "version": "0.0.1",
  "engines": { "vscode": "^1.110.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-git-fixup-panel.fixup",
        "title": "Git: Create Fixup Commit",
        "category": "Git Fixup"
      },
      {
        "command": "vscode-git-fixup-panel.rebaseAutosquash",
        "title": "Git: Rebase Autosquash",
        "category": "Git Fixup"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "vscode-git-fixup-panel.fixup" },
        { "command": "vscode-git-fixup-panel.rebaseAutosquash" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
